<%- include('partials/head') %>
<%- include('partials/nav') %>

<main>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="sm:flex sm:items-center">
      <div class="sm:flex-auto">
        <h1 class="text-2xl font-bold tracking-tight text-gray-900">Stations</h1>
        <p class="mt-2 text-sm text-gray-700">Manage your Field Day stations. Each station operates on a specific band and mode.</p>
      </div>
      <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
        <button type="button" onclick="document.getElementById('addStationModal').classList.remove('hidden')" class="block rounded-md bg-indigo-600 px-3 py-2 text-center text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">Add Station</button>
      </div>
    </div>
  </div>

  <!-- Station Cards -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-8">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% stations.forEach(station => { %>
      <div class="overflow-hidden rounded-lg bg-white shadow hover:shadow-md transition-shadow">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold text-gray-900"><%= station.name %></h3>
            <span class="inline-flex items-center rounded-full bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20"><%= station.qso_count %> QSOs</span>
          </div>
          <div class="mt-4 space-y-2">
            <div class="flex items-center text-sm text-gray-500">
              <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10 mr-2"><%= station.band %></span>
              <span class="inline-flex items-center rounded-md bg-purple-50 px-2 py-1 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-700/10 mr-2"><%= station.mode %></span>
              <span class="inline-flex items-center rounded-md bg-yellow-50 px-2 py-1 text-xs font-medium text-yellow-800 ring-1 ring-inset ring-yellow-600/20"><%= station.power %></span>
            </div>
            <div class="text-sm text-gray-500">
              <span class="font-medium">Operator:</span>
              <span class="<%= station.current_operator ? '' : 'italic text-gray-400' %>"><%= station.current_operator || 'Not set' %></span>
            </div>
          </div>
          <div class="mt-4 flex items-center gap-3">
            <a href="/stations/<%= station.id %>" class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">Open Station &rarr;</a>
            <form action="/stations/<%= station.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Delete this station and all its contacts?')">
              <button type="submit" class="text-sm text-red-600 hover:text-red-900">Delete</button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>

      <% if (stations.length === 0) { %>
      <div class="col-span-full text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 0 1 7.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 0 1 1.06 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-semibold text-gray-900">No stations</h3>
        <p class="mt-1 text-sm text-gray-500">Get started by adding a new station.</p>
        <div class="mt-6">
          <button type="button" onclick="document.getElementById('addStationModal').classList.remove('hidden')" class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">Add Station</button>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</main>

<!-- Add Station Modal -->
<div id="addStationModal" class="hidden relative z-10" aria-modal="true">
  <div class="fixed inset-0 bg-gray-500/75 transition-opacity" onclick="document.getElementById('addStationModal').classList.add('hidden')"></div>
  <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
    <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
      <div class="relative transform overflow-hidden rounded-lg bg-white px-4 pb-4 pt-5 text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg sm:p-6">
        <form action="/stations" method="POST">
          <div>
            <h3 class="text-lg font-semibold leading-6 text-gray-900 mb-4">Add New Station</h3>
            <div class="space-y-4">
              <div>
                <label for="name" class="block text-sm font-medium leading-6 text-gray-900">Station Name</label>
                <input type="text" name="name" id="name" required class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" placeholder="e.g., Station 1 - 20m CW">
              </div>
              <div>
                <label for="band" class="block text-sm font-medium leading-6 text-gray-900">Band</label>
                <select name="band" id="band" required class="mt-2 block w-full rounded-md bg-white py-1.5 pl-3 pr-10 text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6">
                  <option value="160m">160m</option>
                  <option value="80m">80m</option>
                  <option value="40m">40m</option>
                  <option value="20m" selected>20m</option>
                  <option value="15m">15m</option>
                  <option value="10m">10m</option>
                  <option value="6m">6m</option>
                  <option value="2m">2m</option>
                  <option value="220">220</option>
                  <option value="440">440</option>
                  <option value="SAT">Satellite</option>
                </select>
              </div>
              <div>
                <label for="mode" class="block text-sm font-medium leading-6 text-gray-900">Mode</label>
                <select name="mode" id="mode" required class="mt-2 block w-full rounded-md bg-white py-1.5 pl-3 pr-10 text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6">
                  <option value="CW">CW</option>
                  <option value="SSB">SSB (Phone)</option>
                  <option value="Digital">Digital</option>
                  <option value="FT8">FT8</option>
                  <option value="FT4">FT4</option>
                  <option value="RTTY">RTTY</option>
                </select>
              </div>
              <div>
                <label for="power" class="block text-sm font-medium leading-6 text-gray-900">Power</label>
                <select name="power" id="power" required class="mt-2 block w-full rounded-md bg-white py-1.5 pl-3 pr-10 text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6">
                  <option value="HIGH">High (&gt;150W)</option>
                  <option value="LOW">Low (&le;150W)</option>
                  <option value="QRP">QRP (&le;5W)</option>
                </select>
              </div>
              <div>
                <label for="current_operator" class="block text-sm font-medium leading-6 text-gray-900">Current Operator Callsign</label>
                <input type="text" name="current_operator" id="current_operator" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" placeholder="e.g., W1ABC">
              </div>
            </div>
          </div>
          <div class="mt-5 sm:mt-6 sm:grid sm:grid-flow-row-dense sm:grid-cols-2 sm:gap-3">
            <button type="submit" class="inline-flex w-full justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 sm:col-start-2">Create Station</button>
            <button type="button" onclick="document.getElementById('addStationModal').classList.add('hidden')" class="mt-3 inline-flex w-full justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 sm:col-start-1 sm:mt-0">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

</body>
</html>
