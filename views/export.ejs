<%- include('partials/head') %>
<%- include('partials/nav') %>

<main>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <h1 class="text-2xl font-bold tracking-tight text-gray-900">Export Cabrillo Log</h1>
    <p class="mt-2 text-sm text-gray-700">Generate a Cabrillo-formatted log file for submission. Total contacts: <strong><%= contactCount %></strong></p>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-8">
    <div class="overflow-hidden rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <form action="/export/cabrillo" method="POST">
          <div class="grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-6">
            <div class="sm:col-span-3">
              <label for="callsign" class="block text-sm font-medium leading-6 text-gray-900">Station Callsign</label>
              <input type="text" name="callsign" id="callsign" required class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 uppercase outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" placeholder="e.g., W1ABC">
            </div>
            <div class="sm:col-span-3">
              <label for="fdclass" class="block text-sm font-medium leading-6 text-gray-900">Field Day Class</label>
              <input type="text" name="fdclass" id="fdclass" required class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 uppercase outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" placeholder="e.g., 3A">
            </div>
            <div class="sm:col-span-3">
              <label for="location" class="block text-sm font-medium leading-6 text-gray-900">ARRL Section</label>
              <input type="text" name="location" id="location" required class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 uppercase outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" placeholder="e.g., CT">
            </div>
            <div class="sm:col-span-3">
              <label for="club" class="block text-sm font-medium leading-6 text-gray-900">Club Name</label>
              <input type="text" name="club" id="club" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6">
            </div>
            <div class="sm:col-span-3">
              <label for="name" class="block text-sm font-medium leading-6 text-gray-900">Contact Name</label>
              <input type="text" name="name" id="name" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6">
            </div>
            <div class="sm:col-span-3">
              <label for="address" class="block text-sm font-medium leading-6 text-gray-900">Address</label>
              <input type="text" name="address" id="address" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6">
            </div>
            <div class="sm:col-span-2">
              <label for="city" class="block text-sm font-medium leading-6 text-gray-900">City</label>
              <input type="text" name="city" id="city" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6">
            </div>
            <div class="sm:col-span-2">
              <label for="state_province" class="block text-sm font-medium leading-6 text-gray-900">State/Province</label>
              <input type="text" name="state_province" id="state_province" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6">
            </div>
            <div class="sm:col-span-2">
              <label for="postalcode" class="block text-sm font-medium leading-6 text-gray-900">Postal Code</label>
              <input type="text" name="postalcode" id="postalcode" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6">
            </div>
            <div class="sm:col-span-3">
              <label for="country" class="block text-sm font-medium leading-6 text-gray-900">Country</label>
              <input type="text" name="country" id="country" value="USA" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6">
            </div>
            <div class="sm:col-span-3">
              <label class="block text-sm font-medium leading-6 text-gray-900">Operators</label>
              <p class="mt-2 text-sm text-gray-500 pt-1.5"><%= operators.length > 0 ? operators.join(', ') : 'No operators recorded yet' %></p>
            </div>
            <div class="sm:col-span-6">
              <label for="soapbox" class="block text-sm font-medium leading-6 text-gray-900">Soapbox Comments</label>
              <textarea name="soapbox" id="soapbox" rows="3" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" placeholder="Notes about your Field Day operation..."></textarea>
            </div>
          </div>
          <div class="mt-6">
            <button type="submit" class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
              <svg class="-ml-0.5 mr-1.5 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M10.75 2.75a.75.75 0 0 0-1.5 0v8.614L6.295 8.235a.75.75 0 1 0-1.09 1.03l4.25 4.5a.75.75 0 0 0 1.09 0l4.25-4.5a.75.75 0 0 0-1.09-1.03l-2.955 3.129V2.75z" />
                <path d="M3.5 12.75a.75.75 0 0 0-1.5 0v2.5A2.75 2.75 0 0 0 4.75 18h10.5A2.75 2.75 0 0 0 18 15.25v-2.5a.75.75 0 0 0-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5z" />
              </svg>
              Download Cabrillo Log
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
</body>
</html>
