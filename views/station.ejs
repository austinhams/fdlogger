<%- include('partials/head') %>
<%- include('partials/nav') %>

<main>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <!-- Station Header -->
    <div class="md:flex md:items-center md:justify-between">
      <div class="min-w-0 flex-1">
        <div class="flex items-center">
          <a href="/stations" class="text-sm text-indigo-600 hover:text-indigo-500">&larr; All Stations</a>
        </div>
        <h1 class="mt-2 text-2xl font-bold tracking-tight text-gray-900"><%= station.name %></h1>
        <div class="mt-2 flex items-center space-x-2">
          <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10"><%= station.band %></span>
          <span class="inline-flex items-center rounded-md bg-purple-50 px-2 py-1 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-700/10"><%= station.mode %></span>
          <span class="inline-flex items-center rounded-md bg-yellow-50 px-2 py-1 text-xs font-medium text-yellow-800 ring-1 ring-inset ring-yellow-600/20"><%= station.power %></span>
        </div>
      </div>
    </div>

    <!-- Operator Switch -->
    <div class="mt-6 overflow-hidden rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-base font-semibold leading-6 text-gray-900">Current Operator</h3>
        <div class="mt-2 sm:flex sm:items-center sm:gap-3">
          <form action="/stations/<%= station.id %>/operator" method="POST" class="sm:flex sm:items-center sm:gap-3 w-full">
            <div class="w-full sm:max-w-xs">
              <input type="text" name="current_operator" value="<%= station.current_operator %>" class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" placeholder="Operator callsign (e.g., W1ABC)">
            </div>
            <button type="submit" class="mt-3 inline-flex w-full items-center justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 sm:mt-0 sm:w-auto">Switch Operator</button>
          </form>
        </div>
        <% if (!station.current_operator) { %>
        <p class="mt-2 text-sm text-red-600">&#9888; No operator set. Please set an operator before logging contacts.</p>
        <% } %>
      </div>
    </div>

    <!-- Log Contact Form -->
    <div class="mt-6 overflow-hidden rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-base font-semibold leading-6 text-gray-900">Log Contact</h3>
        <div id="dupeWarning" class="hidden mt-2 rounded-md bg-yellow-50 p-3">
          <div class="flex">
            <div class="text-sm text-yellow-800"><strong>Possible Dupe!</strong> This callsign has already been logged on this band/mode.</div>
          </div>
        </div>
        <form id="logForm" action="/contacts" method="POST" class="mt-4">
          <input type="hidden" name="station_id" value="<%= station.id %>">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-4">
            <div>
              <label for="callsign" class="block text-sm font-medium leading-6 text-gray-900">Callsign</label>
              <input type="text" name="callsign" id="callsign" required autocomplete="off" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 uppercase outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" placeholder="W1ABC">
            </div>
            <div>
              <label for="contactClass" class="block text-sm font-medium leading-6 text-gray-900">Class</label>
              <input type="text" name="class" id="contactClass" required autocomplete="off" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 uppercase outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" placeholder="3A">
            </div>
            <div>
              <label for="section" class="block text-sm font-medium leading-6 text-gray-900">Section</label>
              <div class="relative">
                <input type="text" name="section" id="section" required autocomplete="off" class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 uppercase outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" placeholder="CT">
                <div id="sectionSuggestions" class="hidden absolute z-10 mt-1 max-h-60 w-full overflow-auto rounded-md bg-white py-1 text-base shadow-lg ring-1 ring-black/5 focus:outline-none sm:text-sm"></div>
              </div>
            </div>
            <div class="flex items-end">
              <button type="submit" class="w-full inline-flex justify-center items-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">Log Contact</button>
            </div>
          </div>
          <p class="mt-2 text-sm text-gray-500">Logging as <strong><%= station.current_operator || 'Unknown' %></strong> on <strong><%= station.band %> <%= station.mode %></strong> &middot; Press Enter to submit</p>
        </form>
      </div>
    </div>

    <!-- Contacts Table -->
    <div class="mt-6 overflow-hidden rounded-lg bg-white shadow mb-8">
      <div class="px-4 py-5 sm:p-6">
        <div class="sm:flex sm:items-center">
          <div class="sm:flex-auto">
            <h3 class="text-base font-semibold leading-6 text-gray-900">Contacts (<span id="contactCount"><%= contacts.length %></span>)</h3>
          </div>
        </div>
        <div class="mt-4 overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-300">
            <thead>
              <tr>
                <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">#</th>
                <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Time (UTC)</th>
                <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Callsign</th>
                <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Class</th>
                <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Section</th>
                <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Operator</th>
                <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Actions</th>
              </tr>
            </thead>
            <tbody id="contactsBody" class="divide-y divide-gray-200">
              <% contacts.forEach((contact, index) => { %>
              <tr>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= contacts.length - index %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= new Date(contact.created_at).toISOString().slice(11, 16) %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm font-medium text-gray-900"><%= contact.callsign %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= contact.class %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= contact.section %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= contact.operator %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm">
                  <form action="/contacts/<%= contact.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Delete this contact?')">
                    <button type="submit" class="text-red-600 hover:text-red-900 text-sm">Delete</button>
                  </form>
                </td>
              </tr>
              <% }) %>
              <% if (contacts.length === 0) { %>
              <tr id="noContactsRow">
                <td colspan="7" class="px-3 py-8 text-center text-sm text-gray-500">No contacts logged yet. Start logging above!</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  const stationId = <%- JSON.stringify(station.id) %>;
  const existingCallsigns = <%- JSON.stringify(contacts.map(c => c.callsign)) %>;
</script>
<script src="/js/station.js"></script>
<%- include('partials/footer') %>
</body>
</html>
